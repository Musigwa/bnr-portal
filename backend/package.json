{
  "name": "@bnr-portal/backend",
  "version": "1.0.0",
  "description": "Backend API service for the BNR Licensing & Compliance Portal, built with NestJS and Prisma.",
  "author": "Musigwa",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Musigwa/bnr-portal.git",
    "directory": "backend"
  },
  "files": [
    "dist",
    "prisma",
    "prisma.config.mjs"
  ],
  "scripts": {
    "build": "nest build",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../.prettierignore",
    "migration:deploy": "pnpm with-env prisma migrate deploy",
    "start": "pnpm migration:deploy && pnpm with-env node dist/main.js",
    "dev": "pnpm migration:deploy && pnpm with-env nest start --watch --preserveWatchOutput",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenvx run -f ../.env --ignore=MISSING_ENV_FILE --",
    "test": "jest --verbose",
    "test:e2e": "jest --config ./test/jest-e2e.json --verbose",
    "postinstall": "pnpm prisma generate"
  },
  "dependencies": {
    "@bnr-portal/env": "workspace:*",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "archiver": "^8.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "joi": "^18.2.1",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@testcontainers/postgresql": "^12.0.2",
    "@types/archiver": "^8.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "webpack": "^5.107.2",
    "webpack-node-externals": "^3.0.0"
  }
}
