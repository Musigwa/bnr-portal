{
  "name": "@bnr-portal/frontend",
  "version": "1.0.0",
  "description": "Frontend application for the BNR Licensing & Compliance Portal, built with Next.js and Tailwind CSS.",
  "author": "Musigwa",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Musigwa/bnr-portal.git",
    "directory": "frontend"
  },
  "files": [
    ".next",
    "public"
  ],
  "scripts": {
    "dev": "pnpm with-env next dev",
    "build": "pnpm with-env env NODE_ENV=production next build",
    "start": "pnpm with-env sh -c 'next start -p ${NEXT_FRONTEND_PORT}'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../.prettierignore",
    "with-env": "dotenvx run -f ../.env --ignore=MISSING_ENV_FILE --",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bnr-portal/env": "workspace:*",
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-cookie": "^3.0.5",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5.7.3"
  }
}
