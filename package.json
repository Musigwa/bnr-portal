{
  "name": "bnr-portal",
  "version": "1.0.0",
  "description": "National Bank of Rwanda (BNR) Licensing & Compliance Portal - A high-fidelity, secure, and industrial-grade platform for managing bank licensing applications and regulatory compliance.",
  "author": "Musigwa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Musigwa/bnr-portal.git"
  },
  "bugs": {
    "url": "https://github.com/Musigwa/bnr-portal/issues"
  },
  "homepage": "https://github.com/Musigwa/bnr-portal#readme",
  "scripts": {
    "services:up": "docker compose -f docker-compose.yml -f docker-compose.local.yml --profile development up -d",
    "services:down": "docker compose --profile development down",
    "services:clean": "docker compose --profile development down -v",
    "dev": "pnpm services:up && pnpm with-env turbo run dev",
    "prestart": "pnpm build",
    "start": "pnpm services:up && pnpm with-env turbo run start",
    "build": "pnpm with-env turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint-staged": "lint-staged",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "with-env": "dotenvx run -f .env --ignore=MISSING_ENV_FILE --",
    "env:generate": "pnpm --filter @bnr-portal/env generate",
    "env:validate": "pnpm --filter @bnr-portal/env validate",
    "verify:all": "turbo run validate:turbo format:check lint typecheck test test:e2e build",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx,mjs,cjs,css}": [
      "prettier --write",
      "pnpm --filter @bnr-portal/frontend lint",
      "bash -c 'pnpm --filter @bnr-portal/frontend typecheck'"
    ],
    "backend/**/*.{ts,js,mjs,cjs}": [
      "prettier --write",
      "pnpm --filter @bnr-portal/backend lint",
      "bash -c 'pnpm --filter @bnr-portal/backend typecheck'"
    ]
  },
  "keywords": [
    "bnr",
    "compliance",
    "banking",
    "licensing",
    "portal",
    "nextjs",
    "nestjs"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.73.1",
    "@types/inquirer": "^8.2.13",
    "chalk": "^4.1.2",
    "husky": "^9.1.7",
    "inquirer": "^8.2.7",
    "joi": "^18.2.1",
    "lint-staged": "^15.4.3",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "@scarf/scarf",
      "bcrypt",
      "cpu-features",
      "esbuild",
      "msw",
      "prisma",
      "protobufjs",
      "sharp",
      "ssh2",
      "unrs-resolver"
    ]
  }
}
