{
  "name": "bnr-portal",
  "version": "1.0.0",
  "description": "National Bank of Rwanda (BNR) Licensing & Compliance Portal - A high-fidelity, secure, and industrial-grade platform for managing bank licensing applications and regulatory compliance.",
  "author": "Musigwa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Musigwa/bnr-portal.git"
  },
  "bugs": {
    "url": "https://github.com/Musigwa/bnr-portal/issues"
  },
  "homepage": "https://github.com/Musigwa/bnr-portal#readme",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "install:all": "pnpm install",
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "pnpm -r postinstall",
    "lint-staged": "lint-staged",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "pnpm --filter @bnr-portal/frontend lint",
      "bash -c 'pnpm --filter @bnr-portal/frontend typecheck'"
    ],
    "backend/**/*.ts": [
      "pnpm --filter @bnr-portal/backend lint",
      "bash -c 'pnpm --filter @bnr-portal/backend typecheck'"
    ]
  },
  "keywords": [
    "bnr",
    "compliance",
    "banking",
    "licensing",
    "portal",
    "nextjs",
    "nestjs"
  ],
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  }
}
