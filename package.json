{
  "name": "bnr-portal",
  "version": "1.0.0",
  "description": "National Bank of Rwanda (BNR) Licensing & Compliance Portal - A high-fidelity, secure, and industrial-grade platform for managing bank licensing applications and regulatory compliance.",
  "author": "Musigwa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Musigwa/bnr-portal.git"
  },
  "bugs": {
    "url": "https://github.com/Musigwa/bnr-portal/issues"
  },
  "homepage": "https://github.com/Musigwa/bnr-portal#readme",
  "scripts": {
    "services:up": "docker compose -f docker.compose.yml --env-file .env.development up postgres minio minio-setup -d",
    "services:down": "docker compose -f docker.compose.yml down",
    "dev": "pnpm services:up && turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "postinstall": "pnpm -r postinstall",
    "lint-staged": "lint-staged",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify:all": "turbo run lint typecheck test test:e2e build",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "pnpm --filter @bnr-portal/frontend lint",
      "bash -c 'pnpm --filter @bnr-portal/frontend typecheck'"
    ],
    "backend/**/*.ts": [
      "pnpm --filter @bnr-portal/backend lint",
      "bash -c 'pnpm --filter @bnr-portal/backend typecheck'"
    ]
  },
  "keywords": [
    "bnr",
    "compliance",
    "banking",
    "licensing",
    "portal",
    "nextjs",
    "nestjs"
  ],
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "turbo": "^2.9.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "@scarf/scarf",
      "bcrypt",
      "cpu-features",
      "esbuild",
      "msw",
      "prisma",
      "protobufjs",
      "sharp",
      "ssh2",
      "unrs-resolver"
    ]
  }
}
